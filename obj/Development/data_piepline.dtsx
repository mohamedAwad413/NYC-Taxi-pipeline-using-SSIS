            return (Int32)(ParentComponent.ReadWriteVariables["Number_of_rows"].GetValueWithContext(ScriptComponent.EvaluatorContext));
        }
        set
        {
            ParentComponent.ReadWriteVariables["Number_of_rows"].Value = value;
        }
    }

